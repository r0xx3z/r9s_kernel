menu "ARM GPU Configuration"

choice
	prompt "Valhall driver version"
	default MALI_DDK_VALHALL_R38P0
	help
	  Select the ARM Mali Valhall DDK version to be built.

config MALI_DDK_VALHALL_R38P0
	bool "Valhall r38p0 driver"

config MALI_DDK_VALHALL_R38P1
	bool "Valhall r38p1 driver"

endchoice

if MALI_DDK_VALHALL_R38P0
source "drivers/gpu/arm/bv_r38p0/Kconfig"
endif

if MALI_DDK_VALHALL_R38P1
source "drivers/gpu/arm/bv_r38p1/Kconfig"
endif

endmenu
